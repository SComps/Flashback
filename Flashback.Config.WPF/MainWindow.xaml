<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flashback Configuration Control Center" Height="780" Width="1180"
        WindowStartupLocation="CenterScreen">
    
    <Grid x:Name="MainRoot">
        <Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

        <Border x:Name="navRail" BorderThickness="0,0,1,0" BorderBrush="#33000000">
            <Grid Margin="20">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock x:Name="txtLogo" Text="FLASHBACK" FontSize="20" FontWeight="Bold" Margin="0,0,0,30" Foreground="#0078D4"/>
                    <RadioButton x:Name="btnNavPrinters" IsChecked="True" Click="Nav_Click" GroupName="nav">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,10,0"/><TextBlock Text="Printers &amp; Devices" VerticalAlignment="Center"/></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="btnNavSettings" Click="Nav_Click" GroupName="nav" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,10,0"/><TextBlock Text="Server Settings" VerticalAlignment="Center"/></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="btnNavSecurity" Click="Nav_Click" GroupName="nav" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,10,0"/><TextBlock Text="Security" VerticalAlignment="Center"/></StackPanel>
                    </RadioButton>
                    <Separator Margin="0,20"/>
                    <Button Click="ShowHelp_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,10,0"/><TextBlock Text="Help &amp; Docs" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Row="2"><TextBlock Text="OPS VERSION 2.2" FontSize="10" HorizontalAlignment="Center"/><TextBlock Text="© 2026 FLASHBACK" FontSize="10" HorizontalAlignment="Center"/></StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="40">
            <Grid x:Name="viewPrinters" Visibility="Visible">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid Margin="0,0,0,30">
                    <StackPanel><TextBlock Text="Manage Devices" FontSize="28" FontWeight="SemiBold"/><TextBlock Text="Operations Dashboard" Foreground="#666666"/></StackPanel>
                    <Button Click="AddDevice_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="15,8" Content="Add New Device"/>
                </Grid>
                <ScrollViewer Grid.Row="1"><ItemsControl x:Name="DeviceList">
                    <ItemsControl.ItemTemplate><DataTemplate>
                        <Border BorderThickness="1" BorderBrush="#33000000" CornerRadius="8" Margin="0,0,0,10" Padding="15" Background="White">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="20" Background="#F0F0F0"><TextBlock Text="" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#0078D4"/></Border>
                                <StackPanel Grid.Column="1" Margin="15,0"><TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="{Binding Type}" FontSize="11" Foreground="#666666"/></StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal"><Button Content="" Click="Edit_Click" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Margin="0,0,10,0"/><Button Content="" Click="Delete_Click" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Foreground="Red"/></StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl></ScrollViewer>
            </Grid>

            <Grid x:Name="viewSettings" Visibility="Collapsed">
                <StackPanel><TextBlock Text="Server Settings" FontSize="28" FontWeight="SemiBold"/><Border BorderThickness="1" BorderBrush="#33000000" Padding="20" Margin="0,20,0,0">
                    <StackPanel><TextBlock Text="UI Theme"/><ComboBox x:Name="cmbUITheme" SelectionChanged="cmbUITheme_SelectionChanged" Margin="0,5,0,15"><ComboBoxItem Content="Auto"/><ComboBoxItem Content="Midnight"/><ComboBoxItem Content="Snow"/></ComboBox></StackPanel>
                </Border></StackPanel>
            </Grid>

            <Grid x:Name="viewSecurity" Visibility="Collapsed">
                <StackPanel><TextBlock Text="Security" FontSize="28" FontWeight="SemiBold"/><Border BorderThickness="1" BorderBrush="#33000000" Padding="20" Margin="0,20,0,0">
                    <StackPanel><TextBlock Text="System Password"/><PasswordBox x:Name="pbSysPw" Margin="0,5,0,10"/><Button Content="Update" HorizontalAlignment="Left" Padding="15,5"/></StackPanel>
                </Border></StackPanel>
            </Grid>
        </Grid>

        <Grid x:Name="overlayLock" Grid.ColumnSpan="2" Background="White" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                <TextBlock Text="SECURITY LOCK" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <PasswordBox x:Name="pbLogin" Padding="10" KeyDown="pbLogin_KeyDown"/><Button Content="Unlock" Click="Login_Click" Margin="0,15,0,0" Padding="20,10"/>
                <TextBlock x:Name="lblLoginError" Text="Denied." Foreground="Red" HorizontalAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="overlayHelp" Grid.ColumnSpan="2" Background="#99000000" Visibility="Collapsed">
            <Border Background="White" Width="500" Height="400" Padding="30" CornerRadius="10" VerticalAlignment="Center">
                <StackPanel><TextBlock Text="Help" FontSize="24" FontWeight="Bold"/><TextBlock Text="Flashback Engine Control Center" Margin="0,10,0,20"/><Button Content="Close" Click="CloseHelp_Click" HorizontalAlignment="Right" Padding="15,5"/></StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
