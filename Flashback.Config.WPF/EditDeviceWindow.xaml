<Window x:Class="EditDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Device" Height="500" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Configure Device" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#0078D4"/>

        <TabControl Grid.Row="1">
            <TabItem Header="Identity">
                <StackPanel Margin="10">
                    <TextBlock Text="NAME" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtName" Padding="8"/>
                    <CheckBox x:Name="chkEnabled" Content="Device Enabled" Margin="0,10,0,5" IsChecked="True"/>
                    <TextBlock Text="DESCRIPTION" FontWeight="Bold" Margin="0,15,0,5"/>
                    <TextBox x:Name="txtDesc" Padding="8"/>
                    <TextBlock Text="OS PROFILE" FontWeight="Bold" Margin="0,15,0,5"/>
                    <ComboBox x:Name="cmbOS" Padding="8">
                        <ComboBoxItem Content="OS/MVS 3.8J"/>
                        <ComboBoxItem Content="VMS (Vax)"/>
                        <ComboBoxItem Content="MPE (HP3000)"/>
                        <ComboBoxItem Content="RSTS/E (PDP-11)"/>
                        <ComboBoxItem Content="OS/VM 370"/>
                        <ComboBoxItem Content="NOS (CDC Cyber)"/>
                        <ComboBoxItem Content="OS/VM/SP"/>
                        <ComboBoxItem Content="Tandy Xenix"/>
                        <ComboBoxItem Content="OS/zOS"/>
                        <ComboBoxItem Content="z/VM 7.3"/>
                        <ComboBoxItem Content="Generic Profile"/>
                    </ComboBox>
                </StackPanel>
            </TabItem>

            <TabItem Header="Network">
                <StackPanel Margin="10">
                    <TextBlock Text="DEVICE TYPE" FontWeight="Bold" Margin="0,10,0,5"/>
                    <ComboBox x:Name="cmbType" Padding="8">
                        <ComboBoxItem Content="Printer (RFC1179/LPD)"/>
                        <ComboBoxItem Content="3270 Terminal (TN3270)"/>
                    </ComboBox>
                    <TextBlock Text="CONNECTION METHOD" FontWeight="Bold" Margin="0,15,0,5"/>
                    <ComboBox x:Name="cmbConn" Padding="8">
                        <ComboBoxItem Content="Client (Outbound)"/>
                        <ComboBoxItem Content="Listener (Inbound Port 9100)"/>
                        <ComboBoxItem Content="Batch Processing"/>
                    </ComboBox>
                    <TextBlock Text="SOURCE (IP:PORT)" FontWeight="Bold" Margin="0,15,0,5"/>
                    <TextBox x:Name="txtDest" Padding="8"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Output &amp; PDF">
                <StackPanel Margin="10">
                    <CheckBox x:Name="chkPDF" Content="Generate PDF Documents" Margin="0,10,0,15"/>
                    <TextBlock Text="PAGE ORIENTATION" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbOrient" Padding="8">
                        <ComboBoxItem Content="Landscape (132 Columns)"/>
                        <ComboBoxItem Content="Portrait (80 Columns)"/>
                    </ComboBox>
                    <TextBlock Text="OUTPUT DIRECTORY" FontWeight="Bold" Margin="0,15,0,5"/>
                    <TextBox x:Name="txtOut" Padding="8"/>
                    <TextBlock Text="SHADING THEME" FontWeight="Bold" Margin="0,15,0,5"/>
                    <ComboBox x:Name="cmbShade" Padding="8">
                        <ComboBoxItem Content="IBM Green Paper"/>
                        <ComboBoxItem Content="Modern Blue Paper"/>
                        <ComboBoxItem Content="Standard White"/>
                    </ComboBox>
                </StackPanel>
            </TabItem>
            <TabItem Header="Email">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="chkEmailEnabled" Content="Enable Email Delivery" Margin="0,10,0,15"/>
                        
                        <TextBlock Text="RECIPIENTS (comma-separated)" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtEmailRecipients" Padding="8" TextWrapping="Wrap"/>
                        
                        <TextBlock Text="SMTP Configuration" FontWeight="Bold" Margin="0,20,0,10" FontSize="14"/>
                        
                        <TextBlock Text="SMTP SERVER" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtSmtpServer" Padding="8"/>
                        
                        <TextBlock Text="SMTP PORT" FontWeight="Bold" Margin="0,15,0,5"/>
                        <TextBox x:Name="txtSmtpPort" Padding="8" Text="587"/>
                        
                        <TextBlock Text="SMTP USERNAME" FontWeight="Bold" Margin="0,15,0,5"/>
                        <TextBox x:Name="txtSmtpUsername" Padding="8"/>
                        
                        <TextBlock Text="SMTP PASSWORD" FontWeight="Bold" Margin="0,15,0,5"/>
                        <PasswordBox x:Name="txtSmtpPassword" Padding="8"/>
                        
                        <CheckBox x:Name="chkSmtpUseTLS" Content="Use TLS/SSL Encryption" Margin="0,15,0,0" IsChecked="True"/>
                        
                        <TextBlock Text="Email Template" FontWeight="Bold" Margin="0,20,0,10" FontSize="14"/>
                        
                        <TextBlock Text="FROM ADDRESS" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtEmailFrom" Padding="8" Text="flashback@localhost"/>
                        
                        <TextBlock Text="FROM NAME" FontWeight="Bold" Margin="0,15,0,5"/>
                        <TextBox x:Name="txtEmailFromName" Padding="8" Text="Flashback Print Server"/>
                        
                        <TextBlock Text="SUBJECT TEMPLATE" FontWeight="Bold" Margin="0,15,0,5"/>
                        <TextBox x:Name="txtEmailSubject" Padding="8" Text="Print Job: {JobName} from {DeviceName}"/>
                        
                        <TextBlock Text="BODY TEMPLATE" FontWeight="Bold" Margin="0,15,0,5"/>
                        <TextBox x:Name="txtEmailBody" Padding="8" TextWrapping="Wrap" AcceptsReturn="True" Height="80"/>
                        
                        <TextBlock Text="Available variables: {JobName}, {DeviceName}, {UserName}, {PageCount}, {DateTime}, {Date}, {Time}" 
                                   FontSize="11" 
                                   Foreground="Gray" 
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Discard Changes" Click="Cancel_Click" Padding="20,10" Margin="0,0,10,0" Background="Transparent" BorderThickness="0"/>
            <Button Content="Save Configuration" Click="Save_Click" Padding="30,12" Background="#0078D4" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
