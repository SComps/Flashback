<ContentDialog
    x:Class="Flashback.Config.WinUI.EditDeviceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Flashback.Config.WinUI"
    Title="Configure Device"
    PrimaryButtonText="Save Configuration"
    SecondaryButtonText="Discard Changes"
    DefaultButton="Primary">

    <Grid Width="500" Margin="0,12,0,0">
        <Pivot x:Name="RootPivot">
            <PivotItem Header="Identity">
                <StackPanel Spacing="12" Margin="0,12,0,0">
                    <TextBox x:Name="txtName" Header="NAME" PlaceholderText="Device Name"/>
                    <CheckBox x:Name="chkEnabled" Content="Device Enabled" IsChecked="True"/>
                    <TextBox x:Name="txtDesc" Header="DESCRIPTION" PlaceholderText="Brief description"/>
                    <ComboBox x:Name="cmbOS" Header="OS PROFILE" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="MVS 3.8J"/>
                        <ComboBoxItem Content="VMS (Vax/Alpha)"/>
                        <ComboBoxItem Content="MPE (HP3000)"/>
                        <ComboBoxItem Content="RSTS/E (PDP-11)"/>
                        <ComboBoxItem Content="VM 370"/>
                        <ComboBoxItem Content="NOS (CDC Cyber)"/>
                        <ComboBoxItem Content="VM/SP"/>
                        <ComboBoxItem Content="Tandy Xenix"/>
                        <ComboBoxItem Content="zOS"/>
                        <ComboBoxItem Content="Generic Profile"/>
                    </ComboBox>
                </StackPanel>
            </PivotItem>

            <PivotItem Header="Network">
                <StackPanel Spacing="12" Margin="0,12,0,0">
                    <ComboBox x:Name="cmbType" Header="DEVICE TYPE" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Printer (RFC1179/LPD)"/>
                        <ComboBoxItem Content="3270 Terminal (TN3270)"/>
                    </ComboBox>
                    <ComboBox x:Name="cmbConn" Header="CONNECTION METHOD" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Client (Outbound)"/>
                        <ComboBoxItem Content="Listener (Inbound Port 9100)"/>
                        <ComboBoxItem Content="Batch Processing"/>
                    </ComboBox>
                    <TextBox x:Name="txtDest" Header="SOURCE (IP:PORT)" PlaceholderText="127.0.0.1:9100"/>
                </StackPanel>
            </PivotItem>

            <PivotItem Header="Output &amp; PDF">
                <StackPanel Spacing="12" Margin="0,12,0,0">
                    <CheckBox x:Name="chkPDF" Content="Generate PDF Documents"/>
                    <ComboBox x:Name="cmbOrient" Header="PAGE ORIENTATION" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Landscape (132 Columns)"/>
                        <ComboBoxItem Content="Portrait (80 Columns)"/>
                    </ComboBox>
                    <TextBox x:Name="txtOut" Header="OUTPUT DIRECTORY" PlaceholderText="C:\Flashback\Output"/>
                    <ComboBox x:Name="cmbShade" Header="SHADING THEME" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="IBM Green Paper"/>
                        <ComboBoxItem Content="Modern Blue Paper"/>
                        <ComboBoxItem Content="Standard White"/>
                    </ComboBox>
                </StackPanel>
            </PivotItem>

            <PivotItem Header="Email">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                    <StackPanel Spacing="12" Margin="0,12,0,0">
                        <CheckBox x:Name="chkEmailEnabled" Content="Enable Email Delivery"/>
                        <TextBox x:Name="txtEmailRecipients" Header="RECIPIENTS (comma-separated)" 
                                 PlaceholderText="user@example.com, admin@company.com"
                                 TextWrapping="Wrap"/>
                        
                        <TextBlock Text="SMTP Configuration" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBox x:Name="txtSmtpServer" Header="SMTP SERVER" PlaceholderText="smtp.gmail.com"/>
                        <NumberBox x:Name="numSmtpPort" Header="SMTP PORT" Value="587" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Inline"/>
                        <TextBox x:Name="txtSmtpUsername" Header="SMTP USERNAME" PlaceholderText="username@example.com"/>
                        <PasswordBox x:Name="txtSmtpPassword" Header="SMTP PASSWORD" PlaceholderText="Enter password"/>
                        <CheckBox x:Name="chkSmtpUseTLS" Content="Use TLS/SSL Encryption" IsChecked="True"/>
                        
                        <TextBlock Text="Email Template" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBox x:Name="txtEmailFrom" Header="FROM ADDRESS" PlaceholderText="flashback@localhost"/>
                        <TextBox x:Name="txtEmailFromName" Header="FROM NAME" PlaceholderText="Flashback Print Server"/>
                        <TextBox x:Name="txtEmailSubject" Header="SUBJECT TEMPLATE" 
                                 PlaceholderText="Print Job: {JobName} from {DeviceName}"/>
                        <TextBox x:Name="txtEmailBody" Header="BODY TEMPLATE" 
                                 PlaceholderText="Job details..." 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 Height="100"/>
                        
                        <TextBlock Text="Available variables: {JobName}, {DeviceName}, {UserName}, {PageCount}, {DateTime}, {Date}, {Time}" 
                                   FontSize="11" 
                                   Foreground="Gray" 
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>
        </Pivot>
    </Grid>
</ContentDialog>
